# ─── AWS Authentication ──────────────────────────────────────────────────────
# AWS credentials are entered through the UI at scan time — do NOT set them here.
# For AWS Organizations / SSO multi-account mode, enable below and ensure the
# container has ~/.aws/config populated by running `aws sso login` on the host.

# ─── AWS Organizations (optional — single-account scan needs no server config) ─
AWS_ORGANIZATIONS_ENABLED=false
# AWS_MANAGEMENT_ACCOUNT_ID=   <-- set only for Organizations mode, never commit a real ID
# AWS_ORGANIZATIONS_EXTERNAL_ID=   <-- ExternalId for cross-account roles (leave blank if not required)
AWS_ACCOUNTS_FILE=cloud_accounts.json

# ─── AI Provider (all optional — leave blank to use built-in rule engine) ────
# Set ONE key; the first one found is used automatically (detection order below).
# ANTHROPIC_API_KEY=sk-ant-...          # Claude          — pip install anthropic
# OPENAI_API_KEY=sk-...                 # GPT-4o          — pip install openai
# GOOGLE_API_KEY=AIza...                # Gemini          — pip install google-generativeai
# GEMINI_API_KEY=AIza...                # Gemini (alias)  — same package as above
# GROQ_API_KEY=gsk_...                  # Llama via Groq  — pip install openai
# DEEPSEEK_API_KEY=sk-...               # DeepSeek        — pip install openai
# XAI_API_KEY=xai-...                   # Grok (xAI)      — pip install openai
# MISTRAL_API_KEY=...                   # Mistral         — pip install openai
# COHERE_API_KEY=...                    # Cohere          — pip install openai
# TOGETHER_API_KEY=...                  # Together AI     — pip install openai
# PERPLEXITY_API_KEY=pplx-...           # Perplexity      — pip install openai
# AZURE_OPENAI_API_KEY=...              # Azure OpenAI    — pip install openai
# AZURE_OPENAI_ENDPOINT=https://...     # Required with AZURE_OPENAI_API_KEY
# BEDROCK_REGION=us-east-1              # AWS Bedrock (uses boto3 credentials, no API key)
# OLLAMA_BASE_URL=http://localhost:11434 # Ollama local (no API key)

# Force a specific provider when multiple keys are set:
# AI_PROVIDER=anthropic   # one of: anthropic openai google gemini groq deepseek xai
#                         #         mistral cohere together perplexity azure bedrock ollama

# Override the default model for the chosen provider:
# AI_MODEL=claude-opus-4-8

# ─── Database ────────────────────────────────────────────────────────────────
# When running via docker-compose, DATABASE_URL is constructed automatically from
# POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB in the root .env — no change needed.
# For local development (outside Docker), point this to your local Postgres instance:
# DATABASE_URL=postgresql://costdetective:yourpassword@localhost:5432/costdetective

# ─── Capacity tuning (all optional — defaults shown) ─────────────────────────
# MAX_CONCURRENT_SCANS=5       # Platform-wide parallel scan limit
# MAX_ANALYSES_PER_USER=3      # Per-user concurrent scan limit
# SCAN_TASK_TIMEOUT=600        # Per-scan timeout in seconds
# ANALYSIS_RETENTION_DAYS=2    # Auto-delete analyses older than N days

# ─── Observability ───────────────────────────────────────────────────────────
# ENABLE_METRICS=false         # Expose /metrics (Prometheus) endpoint when true
#                              # Requires: pip install prometheus-fastapi-instrumentator

# ─── Public Access / CORS ────────────────────────────────────────────────────
# Comma-separated list of browser origins allowed to call the API.
# Set this to your server's public IP (and port 3000) when deploying publicly.
#
# Examples:
#   ALLOWED_ORIGINS=http://1.2.3.4:3000
#   ALLOWED_ORIGINS=http://1.2.3.4:3000,http://myapp.com
#   ALLOWED_ORIGINS=*
#
# When running via docker-compose, ALLOWED_ORIGINS defaults to localhost origins.
# ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Runtime ─────────────────────────────────────────────────────────────────
# DEBUG=false            # Set true to enable Swagger UI at /docs; disables cookie Secure flag
# LOG_FORMAT=json        # json (default) or text
# UVICORN_WORKERS=1      # MUST stay at 1 — rate-limit buckets and SSO sessions are in-memory.
#                        # Multiple workers split state silently. Increase only after Redis is added.

# ─── OAuth / Social Login (all optional) ──────────────────────────────────────
# GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
# LINKEDIN_OAUTH_CLIENT_ID=your-linkedin-client-id
# LINKEDIN_OAUTH_CLIENT_SECRET=your-linkedin-client-secret
# GITHUB_OAUTH_CLIENT_ID=your-github-client-id
# GITHUB_OAUTH_CLIENT_SECRET=your-github-client-secret

# ─── Email / Notifications (all optional) ─────────────────────────────────────
# NOTIFICATIONS_ENABLED=true
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# NOTIFICATION_FROM_EMAIL=alerts@costdetective.dev
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ─── Security ────────────────────────────────────────────────────────────────
# JWT_SECRET is auto-generated on first run and persisted in the backend_data Docker volume.
# Leave blank when using docker-compose — manual setting is NOT required.
# JWT_SECRET=
